# ======================================================================
# MODO LOCAL (padrão deste projeto agora): SQLite + auth própria, sem
# precisar criar nenhuma conta externa. É só copiar este arquivo para
# .env e rodar. Veja a seção PRODUÇÃO mais abaixo para quando for
# publicar o site de verdade.
# ======================================================================

DATABASE_URL="file:./dev.db"

# Gere um valor aleatório novo, ex: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=""

# Credenciais do admin criado por `npm run db:seed` (opcional, tem default)
SEED_ADMIN_EMAIL="admin@imobiliaria.local"
SEED_ADMIN_PASSWORD="admin123"

# Opcional: sem isso, e-mails de novo lead só aparecem no console do servidor.
# RESEND_API_KEY=""
# EMAIL_FROM="Site Imobiliaria <onboarding@resend.dev>"

NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ======================================================================
# PRODUÇÃO (Supabase): variáveis usadas quando o datasource do Prisma
# voltar a ser "postgresql" e o storage/auth migrarem para Supabase.
# ======================================================================
# DATABASE_URL="postgresql://postgres:[PASSWORD]@[HOST]:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres"
# NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT_REF].supabase.co"
# NEXT_PUBLIC_SUPABASE_ANON_KEY="[ANON_PUBLIC_KEY]"
# SUPABASE_SERVICE_ROLE_KEY="[SERVICE_ROLE_KEY]"
