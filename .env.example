# ======================================================================
# Banco de dados (Supabase Postgres)
# Painel do Supabase > Project Settings > Database > Connect
# ======================================================================
# DATABASE_URL: connection pooling (Transaction pooler, porta 6543) — usada
# pela aplicação em runtime.
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@[POOLER_HOST]:6543/postgres"
# DIRECT_URL: conexão direta (porta 5432) — usada só para rodar migrations.
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

# ======================================================================
# Supabase (Auth + Storage)
# Painel do Supabase > Project Settings > API Keys
# ======================================================================
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT_REF].supabase.co"
# "Publishable key" (anon) — segura para expor no browser
NEXT_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_..."
# "Secret key" (service_role) — NUNCA expor ao browser, só em server actions
SUPABASE_SERVICE_ROLE_KEY="sb_secret_..."

# ======================================================================
# Seed (cria o admin no Supabase Auth + imóveis de exemplo)
# ======================================================================
SEED_ADMIN_EMAIL="admin@suaimobiliaria.com"
SEED_ADMIN_PASSWORD="escolha-uma-senha-forte"

# ======================================================================
# E-mail transacional (opcional)
# Sem RESEND_API_KEY, os e-mails de novo lead só são logados no console —
# útil para testar localmente sem precisar configurar isso de início.
# ======================================================================
# RESEND_API_KEY=""
# EMAIL_FROM="Site Imobiliaria <onboarding@resend.dev>"

NEXT_PUBLIC_SITE_URL="http://localhost:3000"
