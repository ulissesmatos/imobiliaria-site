# ---- Banco de dados (Supabase Postgres) ----
# Painel do Supabase > Project Settings > Database > Connection string
# DATABASE_URL: connection pooling (pgbouncer), usada pela aplicacao em runtime
DATABASE_URL="postgresql://postgres:[PASSWORD]@[HOST]:6543/postgres?pgbouncer=true"
# DIRECT_URL: conexao direta, usada apenas para rodar migrations
DIRECT_URL="postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres"

# ---- Supabase (Auth + Storage) ----
# Painel do Supabase > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT_REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="[ANON_PUBLIC_KEY]"
# Chave secreta, NUNCA exposta ao browser - usada só em server actions para upload/admin
SUPABASE_SERVICE_ROLE_KEY="[SERVICE_ROLE_KEY]"

# ---- E-mail transacional (Resend) ----
RESEND_API_KEY="[RESEND_API_KEY]"
# E-mail remetente verificado no Resend (ou onboarding@resend.dev em modo teste)
EMAIL_FROM="Site Imobiliaria <onboarding@resend.dev>"

# ---- Geral ----
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
