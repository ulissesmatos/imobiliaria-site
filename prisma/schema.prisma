// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ================= ENUMS =================

enum TipoNegocio {
  VENDA
  ALUGUEL
}

enum TipoImovel {
  APARTAMENTO
  CASA
  CASA_CONDOMINIO
  COBERTURA
  KITNET_STUDIO
  TERRENO_LOTE
  SALA_COMERCIAL
  GALPAO
  CHACARA_SITIO_FAZENDA
  OUTRO
}

enum StatusImovel {
  DISPONIVEL
  RESERVADO
  VENDIDO
  ALUGADO
  INATIVO
}

enum StatusLead {
  NOVO
  EM_CONTATO
  VISITA_AGENDADA
  FECHADO
  PERDIDO
}

enum OrigemLead {
  PAGINA_IMOVEL
  PAGINA_CONTATO
}

enum AdminRole {
  ADMIN
  SUPERADMIN
}

// ================= MODELOS =================

// Modo local/dev: login e senha vivem aqui (passwordHash). Em produção, migrar
// para Supabase Auth (id passa a ser o auth.users.id, remove-se passwordHash).
model AdminProfile {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String
  role         AdminRole @default(ADMIN)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  properties Property[] @relation("PropertyCreatedBy")

  @@map("admin_profiles")
}

// Singleton: sempre id = 1. Fonte de tudo que seria hardcoded (nome/logo/contato).
model SiteSettings {
  id             Int      @id @default(1)
  siteName       String
  logoUrl        String?
  faviconUrl     String?
  primaryColor   String?
  secondaryColor String?
  aboutText      String?
  heroImageUrl   String?
  creci          String?
  contactEmail   String?
  contactPhone   String?
  whatsappNumber String?
  addressLine    String?
  instagramUrl   String?
  facebookUrl    String?
  youtubeUrl     String?
  updatedAt      DateTime @updatedAt

  @@map("site_settings")
}

model Property {
  id          String       @id @default(cuid())
  slug        String       @unique
  title       String
  description String
  tipoNegocio TipoNegocio
  tipoImovel  TipoImovel
  status      StatusImovel @default(DISPONIVEL)

  // preco
  priceSale Decimal?
  priceRent Decimal?
  condoFee  Decimal?
  iptuValue Decimal?
  showPrice Boolean  @default(true)
  sortPrice Decimal?

  // caracteristicas
  bedrooms     Int      @default(0)
  suites       Int      @default(0)
  bathrooms    Int      @default(0)
  parkingSpots Int      @default(0)
  areaTotal    Decimal?
  areaUsable   Decimal?

  // endereco
  addressStreet     String
  addressNumber     String?
  addressComplement String?
  neighborhood       String
  city               String
  state               String 
  zipCode             String
  latitude            Decimal?
  longitude           Decimal?

  featured   Boolean @default(false)
  viewsCount Int     @default(0)

  createdById String?
  createdBy   AdminProfile? @relation("PropertyCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  images PropertyImage[]
  leads  Lead[]

  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status, tipoNegocio, tipoImovel])
  @@index([city, neighborhood])
  @@index([sortPrice])
  @@map("properties")
}

model PropertyImage {
  id          String   @id @default(cuid())
  propertyId  String
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  url         String
  storagePath String
  order       Int      @default(0)
  isCover     Boolean  @default(false)
  altText     String?
  createdAt   DateTime @default(now())

  @@index([propertyId, order])
  @@map("property_images")
}

model Lead {
  id            String     @id @default(cuid())
  propertyId    String?
  property      Property?  @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  name          String
  email         String
  phone         String
  message       String
  status        StatusLead @default(NOVO)
  origem        OrigemLead @default(PAGINA_IMOVEL)
  internalNotes String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([status])
  @@index([propertyId])
  @@map("leads")
}
